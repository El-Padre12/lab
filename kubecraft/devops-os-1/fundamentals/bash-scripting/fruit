#!/bin/bash

# Description: takes in a fruit name as an argument and tells the color

if [[ $# -ne 1 ]]; then
	echo "Usage: $0 <fruit>" >&2
	exit 1
fi

fruit="$1"

case "$fruit" in 
	apple) 
		echo "Red or Green"
		;;
	banana)
		echo "Yellow"
		;;
	grape)
		echo "Green or Red"
		;;
	*)
		echo "Unknown fruit: $fruit" >&2
		exit 1
		;;
esac
